        mkdir -p $(dirname {log})

        echo "Generating fastp summary CSV for concat mode: $(date)" > {log}
        echo "Input directory: {params.input_dir}" >> {log}
        echo "Output CSV: {output.summary_csv}" >> {log}

        python {params.script} \
            -i {params.input_dir} \
            -o {output.summary_csv} \
            >> {log} 2>&1

        echo "Completed: $(date)" >> {log}
        """

