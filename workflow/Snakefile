        consensus_threshold=fasta_cleaner_params["consensus_threshold"]
    threads: 1
    resources:
        mem_mb=1024
    retries: 3
    shell:
        """
        set -euo pipefail
        python {params.script} \\
            --input {input.all_cons_combined} \\
            --tsv {output.tsv_barcode_count} \\
            --log {output.log_barcode_count}
        """




